# Server
PORT=5000
CORS_ORIGIN=*

# Resend — leave RESEND_API_KEY empty to skip outbound email in dev.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY="re_ZXXXXXXXXXXXXXX"
# Must be on a domain verified in Resend (or use onboarding@resend.dev for testing).
FROM_EMAIL="test@example.com"
# Internal mailbox that receives a copy of every booking request.
AGENCY_EMAIL="test@example.com"

{
  "name": "tours-booking-backend",
  "version": "0.2.0",
  "description": "Express API for the Tours Booking Platform",
  "private": true,
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "junit.xml",
    "classNameTemplate": "{filepath}",
    "titleTemplate": "{title}"
  },
  "engines": {
    "node": ">=18"
  }
}
